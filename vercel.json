{
  "version": 2,
  "public": true,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/data.json", "dest": "/public/data.json" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
