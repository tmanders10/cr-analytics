{
  "version": 2,
  "public": true,
  "builds": [
    { "src": "api/refresh.js", "use": "@vercel/node" },
    { "src": "api/refresh-matches.js", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/refresh-matches", "dest": "/api/refresh-matches.js" },
    { "src": "/api/refresh", "dest": "/api/refresh.js" },
    { "src": "/data.json", "dest": "/public/data.json" },
    { "src": "/logo.png", "dest": "/public/logo.png" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
